# ============================================================
# LLM Gateway Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to version control
# ============================================================

# --- Provider API Keys (set on host, passed into gateway) ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Gateway Config (used by agents) ---
LLM_BASE_URL=http://localhost:4000       # Use http://llm-gateway:4000 inside Docker
LLM_API_KEY=virtual-master-key           # Must match general_settings.master_key in config.yaml
LLM_MODEL=gpt-4                          # Default model name (must match model_name in config.yaml)

# --- Observability (optional) ---
ARIZE_SPACE_KEY=
ARIZE_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
